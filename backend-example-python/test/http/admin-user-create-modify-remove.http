### 创建
< {%
    const rnd = $random.name.username;
    client.global.set('username', rnd);
%}
POST http://{{host}}/api/admin/user/create
Content-Type: application/json
Access-Token: {{accessToken}}

{
  "username": "{{username}}",
  "password": "password",
  "confirmPassword": "password",
  "nickname": "{{username}}",
  "mobile": ""
}

> {%
    client.global.set("userId", response.body.data.id);
%}

### 创建后获取
GET http://{{host}}/api/admin/user/get?id={{userId}}
Access-Token: {{accessToken}}

### 更新手机
POST http://{{host}}/api/admin/user/modify
Content-Type: application/json
Access-Token: {{accessToken}}

{
  "id": "{{userId}}",
  "username": "{{username}}",
  "password": "password",
  "confirmPassword": "password",
  "nickname": "{{username}}",
  "mobile": "138{{$random.integer(10000000, 99999999)}}"
}

### 更新手机后获取
GET http://{{host}}/api/admin/user/get?id={{userId}}
Access-Token: {{accessToken}}

### 删除
POST http://{{host}}/api/admin/user/remove
Access-Token: {{accessToken}}

{
  "id": "{{userId}}"
}

### 删除后获取
GET http://{{host}}/api/admin/user/get?id={{userId}}
Access-Token: {{accessToken}}


