### 准备
< {%
    const rnd = $random.name.username;
    client.global.set('username', rnd);
%}
GET http://{{host}}/api/.well-known

### 注册
POST http://{{host}}/api/user/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "password",
  "confirmPassword": "password",
  "nickname": "{{username}}"
}

> {%
%}

### 登录
POST http://{{host}}/api/user/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "password"
}

> {%
    client.global.set('accessToken', response.body.data.accessToken);
%}

### 取用户信息
GET http://{{host}}/api/user/profile
Access-Token: {{accessToken}}

