### 准备
< {%
    client.global.set('secret', 'jwt-secret-must-long-than-32-str');

    const d = new Date(Date.now() + 60 * 60 * 1000);
    const pad = (n) => String(n).padStart(2, '0');
    const yyyy = d.getFullYear();
    const MM = pad(d.getMonth() + 1);
    const dd = pad(d.getDate());
    const HH = pad(d.getHours());
    const mm = pad(d.getMinutes());
    const ss = pad(d.getSeconds());
    client.global.set('expiresAt', `${yyyy}-${MM}-${dd} ${HH}:${mm}:${ss}`);
%}
GET http://{{host}}/api/.well-known

### JWT 编码
POST http://{{host}}/api/test/crypto/jwt-encode
Content-Type: application/json

{
  "secret": "{{secret}}",
  "expiresAt": "{{expiresAt}}",
  "payload": {
    "string": "test",
    "boolean": true,
    "number": 123
  }
}

> {%
    console.log(response.body);
    client.global.set('token', response.body.data.token);
%}

### JWT 解码，正确的 secret
POST http://{{host}}/api/test/crypto/jwt-decode
Content-Type: application/json

{
  "secret": "{{secret}}",
  "token": "{{token}}"
}

> {%
    console.log(response.body);
%}

### JWT 解码，错误的 secret
POST http://{{host}}/api/test/crypto/jwt-decode
Content-Type: application/json

{
  "secret": "{{$random.uuid}}",
  "token": "{{token}}"
}

> {%
    console.log(response.body);
%}

### JWT 编码，已过期
< {%
    client.global.set('expiresAtExpired', '2025-01-01 00:00:00');
%}
POST http://{{host}}/api/test/crypto/jwt-encode
Content-Type: application/json

{
  "secret": "{{secret}}",
  "expiresAt": "{{expiresAtExpired}}",
  "payload": {
    "string": "test",
    "boolean": true,
    "number": 123
  }
}

> {%
    console.log(response.body);
    client.global.set('tokenExpired', response.body.data.token);
%}

### JWT 解码，已过期
POST http://{{host}}/api/test/crypto/jwt-decode
Content-Type: application/json

{
  "secret": "{{secret}}",
  "token": "{{tokenExpired}}"
}

> {%
    console.log(response.body);
%}

### BASE64 编码
GET http://{{host}}/api/test/crypto/base64-encode?text=hello

> {%
    console.log(response.body);
    client.global.set('base64', response.body.data.base64);
%}

### BASE64 解码
GET http://{{host}}/api/test/crypto/base64-decode?base64={{base64}}

> {%
    console.log(response.body);
%}

### MD5 编码
GET http://{{host}}/api/test/crypto/md5-encode?text=hello

> {%
    console.log(response.body);
%}
