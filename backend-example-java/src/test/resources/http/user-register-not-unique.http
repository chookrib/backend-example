### 准备
< {%
    const rnd = $random.name.username;
    client.global.set('username', rnd);
%}
GET http://{{host}}/api/.well-known

### 注册
POST http://{{host}}/api/user/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "password",
  "confirmPassword": "password",
  "nickname": "{{username}}"
}

### 注册重复用户名
POST http://{{host}}/api/user/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "password",
  "confirmPassword": "password",
  "nickname": "{{username}}"
}


